<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Laoba.App.MainWindow"
        x:CompileBindings="False"
        Title="老八 EDL 刷机工具"
        Width="1280"
        Height="760"
        MinWidth="1080"
        MinHeight="650"
        WindowStartupLocation="CenterScreen">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="18" RowSpacing="12">

    <Border Grid.Row="0" Classes="card" Padding="14">
      <Grid ColumnDefinitions="420,12,*,8,44,12,118" RowDefinitions="Auto,8,Auto">
        <TextBlock Grid.Column="0" Text="内置引导" FontWeight="SemiBold" />

        <ComboBox x:Name="LoaderComboBox"
                  Classes="loader"
                  Grid.Row="2"
                  Grid.Column="0"
                  Width="420"
                  MaxDropDownHeight="470"
                  HorizontalAlignment="Left"
                  HorizontalContentAlignment="Stretch"
                  ToolTip.Tip="严格按资源包 Config.xml 原始顺序显示；中文名称仅用于界面，实际引导文件保持原格式">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <Border Height="36" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplayName}"
                           MaxWidth="380"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           ToolTip.Tip="{Binding Loader}"
                           TextTrimming="CharacterEllipsis" />
              </Border>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBox x:Name="XmlPathTextBox"
                 Grid.Row="2"
                 Grid.Column="2"
                 PlaceholderText="XML 文件"
                 TextAlignment="Center"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 IsReadOnly="True"
                 ToolTip.Tip="选择 rawprogram XML 文件" />
        <Button Grid.Row="2"
                Grid.Column="4"
                Content="📁"
                FontSize="16"
                Padding="0"
                ToolTip.Tip="选择 XML 文件"
                Click="BrowseXml_Click" />

        <Button Grid.Row="2" Grid.Column="6" Classes="primary" Content="检测 9008" Click="DetectDevice_Click" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="card" Padding="12">
      <Grid ColumnDefinitions="Auto,260,*,Auto,Auto" ColumnSpacing="10">
        <TextBlock VerticalAlignment="Center" Text="搜索分区" FontWeight="SemiBold" />
        <TextBox x:Name="PartitionSearchTextBox"
                 Grid.Column="1"
                 PlaceholderText="请输入准确分区名…" />
        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="#7A828C"
                   Text="点击右侧操作后，工具会持续等待设备进入 Qualcomm 9008 模式" />
        <Button Grid.Column="3" Content="导出日志" Click="ExportLog_Click" />
        <Button Grid.Column="4" Content="打开工作目录" Click="OpenWorkDirectory_Click" />
      </Grid>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="270,12,*,12,300">
      <Border Grid.Column="0" Classes="card">
        <Grid RowDefinitions="52,*">
          <Grid ColumnDefinitions="*,42" Margin="14,0,8,0">
            <TextBlock VerticalAlignment="Center" Text="日志" FontSize="15" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="×" ToolTip.Tip="清空日志" Click="ClearLog_Click" />
          </Grid>
          <Border Grid.Row="1" BorderBrush="#EEF0F3" BorderThickness="0,1,0,0">
            <TextBox x:Name="LogTextBox"
                     Text=""
                     Margin="10"
                     Padding="8"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     FontFamily="Consolas, Microsoft YaHei UI"
                     FontSize="12"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="2" Classes="card">
        <Grid RowDefinitions="48,*">
          <Grid ColumnDefinitions="66,54,1.4*,1.2*,100,1.2*" Background="#FAFBFC">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Text="LUN" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="#" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Text="分区名称" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Text="起始扇区" />
            <TextBlock Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" Text="大小" />
            <TextBlock Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center" Text="文件" />
          </Grid>

          <Grid Grid.Row="1">
            <ListBox x:Name="PartitionListBox" Background="Transparent" BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="66,54,1.4*,1.2*,100,1.2*" Height="38">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding Lun}" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding Index}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Text="{Binding Name}" />
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding StartSector}" />
                    <TextBlock Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding Size}" />
                    <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="10,0" Text="{Binding File}" TextTrimming="CharacterEllipsis" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="EmptyPartitionPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
              <TextBlock HorizontalAlignment="Center" Text="▱" Foreground="#C4C9D0" FontSize="42" />
              <TextBlock Text="未加载分区表" Foreground="#8A9099" FontSize="14" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="4"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    HorizontalContentAlignment="Stretch">
        <StackPanel Spacing="10" HorizontalAlignment="Stretch">
          <Border Classes="card" Padding="14" HorizontalAlignment="Stretch">
            <StackPanel Spacing="10" HorizontalAlignment="Stretch">
              <TextBlock Text="刷入操作" FontSize="15" FontWeight="SemiBold" />
              <Button Classes="action" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="▶  刷入（已选）" Click="FlashSelected_Click" />
              <Button Classes="action" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="▣  刷入指定目录全部文件" Click="FlashFolder_Click" />
              <Button Classes="action" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="▤  整机分区备份" Click="BackupAll_Click" />
            </StackPanel>
          </Border>

          <Border Classes="card" Padding="14" HorizontalAlignment="Stretch">
            <StackPanel Spacing="10" HorizontalAlignment="Stretch">
              <TextBlock Text="回读操作" FontSize="15" FontWeight="SemiBold" />
              <Button Classes="action" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="⇩  回读（已选）" Click="ReadSelected_Click" />
              <Button Classes="action" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="≡  读取设备分区表" Click="ReadPartitionTable_Click" />
            </StackPanel>
          </Border>

          <Border Classes="card" Padding="14" HorizontalAlignment="Stretch">
            <StackPanel Spacing="10" HorizontalAlignment="Stretch">
              <TextBlock Text="擦除操作" FontSize="15" FontWeight="SemiBold" />
              <Button Classes="danger" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="⌫  擦除（已选）" Click="EraseSelected_Click" />
            </StackPanel>
          </Border>

          <Border Classes="card" Padding="14" HorizontalAlignment="Stretch">
            <StackPanel Spacing="10" HorizontalAlignment="Stretch">
              <TextBlock Text="其他操作" FontSize="15" FontWeight="SemiBold" />
              <Button Classes="action" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="↻  恢复出厂设置" Click="FactoryReset_Click" />
              <Button Classes="action" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="⏻  重启设备" Click="ResetDevice_Click" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <Grid Grid.Row="3" ColumnDefinitions="Auto,*">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Ellipse Width="9" Height="9" Fill="#18B566" VerticalAlignment="Center" />
        <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Text="就绪" />
      </StackPanel>
      <ProgressBar x:Name="BusyProgressBar" Grid.Column="1" IsIndeterminate="True" IsVisible="False" Height="3" Margin="24,8,0,0" />
    </Grid>
  </Grid>
</Window>